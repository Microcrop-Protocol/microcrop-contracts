# MicroCrop Deployment Environment Variables
# Copy this file to .env and fill in your values

# =================================
# Network Configuration
# =================================

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Basescan API key for contract verification
BASESCAN_API_KEY=your_basescan_api_key

# =================================
# Deployment Account
# =================================

# Private key for deployment (NEVER commit this with real values!)
# Alternatively, use --account deployer with a Foundry keystore
PRIVATE_KEY=0x...

# Deployer EOA address (must match the keystore/private key account)
# Used as initial admin during deployment for role setup
DEPLOYER_ADDRESS=0x...

# =================================
# Contract Configuration
# =================================

# USDC Token Address
# Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Admin address — receives DEFAULT_ADMIN_ROLE on all contracts
# For mainnet: use deployer EOA initially, then transfer to multisig via transfer-admin.sh
ADMIN_ADDRESS=0x...

# Backend wallet that receives payouts for M-Pesa conversion
BACKEND_WALLET=0x...

# Protocol wallet for fee collection (defaults to ADMIN_ADDRESS if not set)
PROTOCOL_WALLET=0x...

# =================================
# Post-Deployment (transfer-admin.sh)
# =================================

# Safe multisig address to receive admin roles after deployment
ADMIN_MULTISIG=0x...

# =================================
# Chainlink Configuration (future use)
# =================================

# Chainlink Keystone Forwarder address
KEYSTONE_FORWARDER=0x...

# Chainlink workflow address for damage reports
WORKFLOW_ADDRESS=0x...

# Chainlink workflow ID
WORKFLOW_ID=12345
